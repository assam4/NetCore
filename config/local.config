http {
    server {
        listen 8080;
        server_name localhost;

        client_max_body_size 10m;
        root /home/lenovo/Desktop/Webserv/www/html;
        index index.html;

        error_page 404 /404.html;
        error_page 500 /50x.html;

        location / {
            allowed_methods GET;
        }

        # We will add upload location here later
    }
}
