http {
    server {
        listen 8081;
        server_name web1.local;
        client_max_body_size 10m;
        root /home/lenovo/Desktop/Webserv/www/html/Webpage1;
        index index.html index.htm;
        autoindex off;
        error_page 404 /404.html;
        error_page 500 502 503 504 /50x.html;
        allowed_methods GET POST;
        location / {
            root /home/lenovo/Desktop/Webserv/www/html/Webpage1;
            index index.html index.htm;
            autoindex off;
            allowed_methods GET POST;
        }
        location /api {
            root /home/lenovo/Desktop/Webserv/www/html/Webpage1/api;
            allowed_methods GET POST;
            autoindex off;
        }
        location /static {
            root /home/lenovo/Desktop/Webserv/www/html/Webpage1/static;
            autoindex on;
            allowed_methods GET;
        }
        location /upload {
            upload_location /tmp/uploads;
            client_max_body_size 50m;
            allowed_methods POST;
        }
        location = /health {
            return 301 /health.txt;
        }
    }

