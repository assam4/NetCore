            return 302 /health.txt;

        }

    }


    server {

        listen 8080;

        server_name py_shared.local;

        client_max_body_size 10m;

        root /home/lenovo/Desktop/Webserv/www/html/Webpage24;

        index index.html index.htm;

        autoindex off;

        error_page 404 /404.html;

        error_page 500 502 503 504 /50x.html;

        allowed_methods GET POST DELETE;

        location / {

            root /home/lenovo/Desktop/Webserv/www/html/Webpage24;

            index index.html index.htm;

            autoindex off;

            allowed_methods GET POST DELETE;

        }

        location /py {

            root /home/lenovo/Desktop/Webserv/www/html/Webpage24;

            cgi_extension .py;

            allowed_methods GET POST;

        }

        location /api {

            root /home/lenovo/Desktop/Webserv/www/html/Webpage24/api;

            allowed_methods GET POST DELETE;

            autoindex off;

        }

        location /static {

            root /home/lenovo/Desktop/Webserv/www/html/Webpage24/static;

            autoindex on;

            allowed_methods GET;

        }

        location /upload {

