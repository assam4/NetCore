http {
    server {
        # LISTEN - обязательно
        listen localhost 20 40;
        listen 8080;


        # SERVER NAMES - для virtual hosts
        server_name example.com www.example.com;

        # CLIENT MAX BODY SIZE - обязательно
        client_max_body_size 10m;

        # ROOT и INDEX - по умолчанию для location'ов
        root /var/www/html;
        index index.html index.htm;

        # ERROR PAGES - обязательно
        error_page 404 /404.html;
        error_page 500 502 503 504 /50x.html;

        # AUTOINDEX
        autoindex off;

        # Default allowed methods
        allowed_methods GET POST;

        # ===== LOCATION БЛОКИ =====

        # Статические файлы
        location / {
            root /var/www/html;
            index index.html;
            autoindex off;
            allowed_methods GET;
        }

        # API endpoint с POST
        location /api {
            root /var/www/api;
            allowed_methods GET POST;
            autoindex off;
        }

        # Upload directory
        location /upload {
            allowed_methods POST;
            upload_location /tmp/uploads;
            client_max_body_size 50m;
        }

        # CGI обработчик для PHP
        location  /a {
            cgi_extension .php;
            root /var/www/html;
        }

        # CGI обработчик для Python
        location =  /a  {
            cgi_extension .py;
            root /var/www/cgi-bin;
        }

        # Редирект старого пути
        location /old_path {
            return 301 /new_path;
        }

        # Статические ресурсы
        location /static {
            root /var/www;
            autoindex on;
            allowed_methods GET;
        }
    }

    # ===== ВТОРОЙ СЕРВЕР (virtual host) =====
    server {
        listen 8081;
        server_name api.example.com;
        root /var/www/api;

        client_max_body_size 5m;

        error_page 404 /api_404.json;

        location / {
            allowed_methods GET POST DELETE;
        }

        location = /temp {
            cgi_extension .php;
        }
    }
}
