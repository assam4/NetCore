http {
	server {
		listen localhost:8080;
		server_name localhost;

		client_max_body_size 10m;
		root /home/lenovo/Desktop/Webserv/www/html;
		index index.html;

		error_page 404 /404.html;
		error_page 500 /50x.html;

		autoindex off;
		allowed_methods GET POST;

		location / {
			root /home/lenovo/Desktop/Webserv/www/html;
			index index.html;
			allowed_methods GET;
			autoindex off;
		}

		location /cgi {
			root /home/lenovo/Desktop/Webserv/www/html;
			cgi_extension .py;
			allowed_methods GET POST;
			autoindex off;
		}

		location /static {
			root /home/lenovo/Desktop/Webserv/www/static;
			allowed_methods GET;
			autoindex off;
		}
	}

	server {
		listen localhost:8081;
		server_name localhost;

		client_max_body_size 10m;
		root /home/lenovo/Desktop/Webserv/www/html;
		index index.html;

		error_page 404 /404.html;
		error_page 500 /50x.html;

		autoindex off;
		allowed_methods GET POST;

		location /php {
			root /home/lenovo/Desktop/Webserv/www/html;
			cgi_extension .php;
			allowed_methods GET POST;
			autoindex off;
		}
	}
}
